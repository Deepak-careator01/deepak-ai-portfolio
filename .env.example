# =============================================================================
# Deepak AI Portfolio — Environment Configuration
# Copy to `.env.local` for local development. Never commit real secrets.
# =============================================================================

# --- Required (chat) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
MAX_CHAT_HISTORY_MESSAGES=10
LLM_MAX_OUTPUT_TOKENS=700

# --- Optional (embeddings / RAG) ---
OPENAI_API_KEY=
EMBEDDING_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Optional (PostgreSQL — memory + pgvector RAG) ---
DATABASE_URL=

# --- Optional (vector store) ---
# Values: pgvector | upstash | none
VECTOR_STORE_PROVIDER=pgvector
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# --- Optional (rate limiting — in-memory by default) ---
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_MS=300000

# --- Optional (RAG tuning) ---
RAG_TOP_K=4
RAG_MAX_CONTEXT_CHARS=5500
RAG_MAX_CHUNK_CHARS=900
RAG_EMBEDDING_CACHE_SIZE=128

# --- Optional (site + ingestion) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
INGEST_CLEAR=false
